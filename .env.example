# Database
DATABASE_URL="postgresql://clantrader:YOUR_PASSWORD@localhost:5432/clantrader_dev"

# Auth.js v5
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Redis
REDIS_URL="redis://localhost:6379"

# Email (leave empty for console logging in dev)
# For Resend: SMTP_HOST="smtp.resend.com", SMTP_PORT=465
# For port 465 use SSL, for 587 use STARTTLS (auto-detected)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="ClanTrader <noreply@clantrader.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ClanTrader"
NODE_OPTIONS="--max-old-space-size=1024"

# Upload
UPLOAD_DIR="public/uploads"
MAX_AVATAR_SIZE_MB=5

# Error tracking (GlitchTip / Sentry)
NEXT_PUBLIC_SENTRY_DSN=""

# Telegram error notifications
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Launch countdown (used by daily digest)
LAUNCH_TARGET_DATE=""
